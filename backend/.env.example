# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
# Option 1: Local MongoDB
MONGODB_URI=mongodb://localhost:27017/ai-diet-assistant

# Option 2: MongoDB Atlas (replace with your connection string)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ai-diet-assistant?retryWrites=true&w=majority

# JWT Secret (generate a random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# Spoonacular API (https://spoonacular.com/food-api)
SPOONACULAR_API_KEY=your_spoonacular_api_key_here

# Edamam Nutrition Analysis API (https://developer.edamam.com/)
EDAMAM_APP_ID=your_edamam_app_id_here
EDAMAM_APP_KEY=your_edamam_app_key_here

# Clarifai API (https://www.clarifai.com/)
CLARIFAI_API_KEY=your_clarifai_api_key_here

# Google Places API (https://developers.google.com/maps/documentation/places/web-service)
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
